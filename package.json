{
  "name": "@lifeops/cli",
  "version": "1.0.0",
  "description": "Relationship intelligence CLI. Because 'fine' rarely means fine.",
  "type": "module",
  "license": "MIT",
  "author": "User",
  "repository": {
    "type": "git",
    "url": "https://github.com/senguttuvang/LifeOps-CLI.git"
  },
  "homepage": "https://github.com/senguttuvang/LifeOps-CLI#readme",
  "bugs": {
    "url": "https://github.com/senguttuvang/LifeOps-CLI/issues"
  },
  "keywords": [
    "relationship",
    "ai",
    "whatsapp",
    "effect-ts",
    "cli",
    "personal-assistant"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "bin": {
    "lifeops": "./src/cli/main.ts"
  },
  "main": "src/cli/main.ts",
  "scripts": {
    "cli": "bun run src/cli/main.ts",
    "sync": "bun run cli sync",
    "decode": "bun run cli decode",
    "remember": "bun run cli remember",
    "health": "bun run cli health",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "bun run tsc --noEmit",
    "lint": "bunx @biomejs/biome check src/",
    "lint:fix": "bunx @biomejs/biome check --write src/",
    "lint:eslint": "eslint src/",
    "lint:eslint:fix": "eslint src/ --fix",
    "lint:all": "bun run lint && bun run lint:eslint",
    "quality": "bun run typecheck && bun run lint:all",
    "quality:full": "bun run quality && bun run quality:arch && bun run quality:knip",
    "quality:qlty": "qlty check --all",
    "quality:qlty:smells": "qlty smells --all",
    "quality:knip": "bunx knip",
    "quality:knip:deps": "bunx knip --dependencies",
    "quality:knip:exports": "bunx knip --exports",
    "quality:arch": "depcruise src --config .dependency-cruiser.cjs",
    "quality:arch:report": "depcruise src --config .dependency-cruiser.cjs --output-type err-html -f dependency-report.html",
    "quality:arch:viz": "depcruise src --config .dependency-cruiser.cjs --output-type dot | dot -T svg > dependency-graph.svg",
    "quality:sonar": "sonar-scanner",
    "quality:sonar:start": "docker run -d --name sonarqube -p 9000:9000 sonarqube:community",
    "quality:eslint:report": "eslint src/ -f json -o eslint-report.json || true",
    "check": "bun run typecheck && bun run lint && bun run test",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@effect/cli": "^0.73.0",
    "@effect/platform": "^0.94.1",
    "@effect/platform-node": "^0.104.0",
    "@effect/schema": "^0.75.5",
    "@lancedb/lancedb": "^0.23.0",
    "better-sqlite3": "^12.5.0",
    "drizzle-orm": "^0.45.1",
    "effect": "^3.19.14",
    "ink": "^6.6.0",
    "ink-spinner": "^5.0.0",
    "ink-table": "^3.1.0",
    "openai": "^6.15.0",
    "pino": "^10.1.0",
    "react": "^19.2.3"
  },
  "devDependencies": {
    "@effect/eslint-plugin": "^0.3.2",
    "@eslint/js": "^9.39.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.8",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "bun-types": "^1.3.5",
    "dependency-cruiser": "^17.3.6",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.39.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-n": "^17.23.1",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-regexp": "^2.10.0",
    "eslint-plugin-sonarjs": "^3.0.5",
    "eslint-plugin-unicorn": "^62.0.0",
    "knip": "^5.80.2",
    "sonarqube-scanner": "^4.3.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
