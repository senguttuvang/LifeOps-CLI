# LifeOps CLI Environment Configuration

# =============================================================================
# WhatsApp Configuration
# =============================================================================

# Self-DM Chat ID (your WhatsApp JID)
# Format: <country_code><phone_number>@s.whatsapp.net
# Example: SELF_CHAT_ID="14155551234@s.whatsapp.net"
SELF_CHAT_ID=

# Self-DM monitor polling interval (seconds)
# Default: 5
POLL_INTERVAL=5

# =============================================================================
# AI & LLM Configuration
# =============================================================================

# Anthropic API Key (for Claude)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenRouter API Key (for vision models & other LLMs)
# Get yours at: https://openrouter.ai/
OPENROUTER_API_KEY=

# =============================================================================
# Feature Flags
# =============================================================================

# Enable vision/OCR event extraction
# Set to "false" to disable vision-based extraction commands
# Default: true
ENABLE_VISION_EXTRACTION=true

# =============================================================================
# Storage Paths (Optional)
# =============================================================================

# SQLite database path
# Default: lifeops.db (in current directory)
# LIFEOPS_DB_PATH=lifeops.db

# LanceDB vector store path
# Default: data/lancedb (relative to current directory)
# LIFEOPS_VECTOR_PATH=data/lancedb

# OpenAI API Key (for embeddings)
# Required for vector search functionality
# Get yours at: https://platform.openai.com/
OPENAI_API_KEY=
